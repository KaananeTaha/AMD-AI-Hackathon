# Copy to .env and fill in your own Fireworks key (fireworks.ai -> API Keys).
# LOCAL DEV ONLY — .env is gitignored/dockerignored; the harness injects the
# real values at evaluation time.
FIREWORKS_API_KEY=fw_your_key_here
FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1
# Hackathon models. The gemmas 404 on personal keys, so glm-5p2 stands in as
# the cheap tier for local runs (harness list works fully at eval).
ALLOWED_MODELS=accounts/fireworks/models/minimax-m3,accounts/fireworks/models/kimi-k2p7-code,accounts/fireworks/models/glm-5p2
MODEL_CHEAP=accounts/fireworks/models/glm-5p2
INPUT_PATH=sample_input/tasks.json
OUTPUT_PATH=sample_output/results.json
